# Palm Orchestration Engine Configuration
# Copy this file to .env and adjust as needed

# Paths
PALM_DATA_DIR=data
PALM_LOG_DIR=logs
PALM_SQLITE_DB=palm_sessions.db

# Session behavior
PALM_DEFAULT_SESSION_TTL_SECONDS=3600
PALM_SESSION_CLEANUP_INTERVAL_SECONDS=300

# Concurrency
PALM_MAX_CONCURRENT_PROCESSES=16

# CLI appearance
PALM_CLI_PROMPT="palm> "

# Logging
PALM_LOG_LEVEL=INFO
PALM_LOG_FORMAT=console

# MCP Docs
PALM_LLMS_TXT=docs/mcp.txt
PALM_SKILL_DIR=docs/skills/palm

# Publish Port
PALM_PUBLISH_PORT=8080